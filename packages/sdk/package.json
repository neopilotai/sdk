{
  "name": "@repolens-ai/sdk",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools/*": {
      "import": "./dist/tools/*.js",
      "types": "./dist/tools/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome lint .",
    "lint:fix": "biome format --write . && biome lint --write .",
    "test": "vitest"
  },
  "dependencies": {
    "ai": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "typescript": "^5.5.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@octokit/rest": "^20.0.0"
  }
}
